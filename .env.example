# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Backend port (default 10756)
PORT=10756

# --- Sampling (agentic workflow / SEP-1577) — default local Ollama OpenAI-compatible API ---
# DISCORD_SAMPLING_BASE_URL=http://127.0.0.1:11434/v1
# DISCORD_SAMPLING_MODEL=llama3.2
# Optional Bearer token (cloud or keyed local proxy)
# DISCORD_SAMPLING_API_KEY=
# Use OPENAI_API_KEY instead (e.g. OpenAI-compatible cloud)
# DISCORD_SAMPLING_USE_OPENAI_KEY=1
# Prefer MCP host LLM for sampling when supported (server handler becomes fallback only)
# DISCORD_SAMPLING_USE_CLIENT_LLM=1

# --- Rate limits and safety (anti-spam) ---
# Max messages per minute (global)
# DISCORD_RATE_LIMIT_MESSAGES_PER_MINUTE=10
# Max messages per channel per minute
# DISCORD_RATE_LIMIT_MESSAGES_PER_CHANNEL_PER_MINUTE=3
# Max channels created per minute
# DISCORD_RATE_LIMIT_CHANNELS_PER_MINUTE=5
# Max invites created per minute
# DISCORD_RATE_LIMIT_INVITES_PER_MINUTE=5
# Max message length (Discord max 2000)
# DISCORD_MAX_MESSAGE_LENGTH=2000
# Min seconds between any two send_message calls
# DISCORD_MIN_MESSAGE_INTERVAL_SECONDS=5.0
